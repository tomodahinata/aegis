{
  "name": "@aegiskit/policy-diff",
  "version": "0.1.0",
  "description": "Semantic access diff for Supabase RLS migrations: turns two migration states into a plain-English access delta (who can newly read/write what), fail-safe by design — for PR review, CI gating, and change-management evidence.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aegiskit/scanner": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "fast-check": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "security",
    "supabase",
    "rls",
    "row-level-security",
    "policy-diff",
    "access-control",
    "ci",
    "appsec"
  ],
  "author": "tomodahinata",
  "homepage": "https://github.com/tomodahinata/aegis/tree/main/packages/policy-diff#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomodahinata/aegis.git",
    "directory": "packages/policy-diff"
  },
  "bugs": "https://github.com/tomodahinata/aegis/issues",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
