{
  "name": "@aegiskit/store-upstash",
  "version": "0.1.0",
  "description": "Atomic, serverless-correct rate-limit store for Aegis, backed by Upstash Redis.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aegiskit/core": "workspace:*"
  },
  "peerDependencies": {
    "@upstash/redis": ">=1.34"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@upstash/redis": "^1.38.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "security",
    "rate-limiting",
    "upstash",
    "redis",
    "serverless",
    "nextjs"
  ],
  "author": "tomodahinata",
  "homepage": "https://github.com/tomodahinata/aegis/tree/main/packages/store-upstash#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomodahinata/aegis.git",
    "directory": "packages/store-upstash"
  },
  "bugs": "https://github.com/tomodahinata/aegis/issues",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
