{
  "name": "@aegiskit/store-supabase",
  "version": "0.1.0",
  "description": "Persistent Aegis EventStore backed by Supabase/Postgres, shipping a migration with Row Level Security enabled by default.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./migrations/0001_aegis_events.sql": "./migrations/0001_aegis_events.sql"
  },
  "files": [
    "dist",
    "migrations",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aegiskit/observability": "workspace:*"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "security",
    "supabase",
    "postgres",
    "rls",
    "event-store",
    "observability"
  ],
  "author": "tomodahinata",
  "homepage": "https://github.com/tomodahinata/aegis/tree/main/packages/store-supabase#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomodahinata/aegis.git",
    "directory": "packages/store-supabase"
  },
  "bugs": "https://github.com/tomodahinata/aegis/issues",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./migrations/0001_aegis_events.sql": "./migrations/0001_aegis_events.sql"
    }
  }
}
