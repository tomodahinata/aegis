# Copy to .env.local and fill in. (Real secrets never belong in git.)

# Admin password for the dashboard login (min 12 chars).
AEGIS_ADMIN_PASSWORD=change-me-to-something-long

# Random secrets, min 32 chars each (e.g. `openssl rand -base64 32`).
AEGIS_SESSION_SECRET=replace-with-32+-random-characters-xxxxx
AEGIS_INGEST_SECRET=replace-with-32+-random-characters-yyyyy

# Optional.
AEGIS_SESSION_TTL_S=86400
AEGIS_RETENTION_MAX=10000
NEXT_PUBLIC_CSP_MODE=report-only
